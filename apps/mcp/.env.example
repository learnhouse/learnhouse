# LearnHouse API base URL. The MCP server proxies requests to this host on
# behalf of each caller's token. No credentials live here — clients supply
# their own Authorization: Bearer lh_... on the MCP connection.
LEARNHOUSE_API_URL=http://localhost:1337

# HTTP bind address and port for the MCP server.
LEARNHOUSE_MCP_HOST=0.0.0.0
LEARNHOUSE_MCP_PORT=8765

# Mount path where the MCP Streamable HTTP endpoint is exposed.
# Clients connect to e.g. https://mcp.example.com/mcp
LEARNHOUSE_MCP_MOUNT_PATH=/mcp

# How long (seconds) to cache the token → org mapping returned by /auth/me.
# Kept short so revoked tokens stop working quickly.
LEARNHOUSE_MCP_TOKEN_CACHE_TTL=300

# Maximum number of distinct tokens to keep resolved in memory.
LEARNHOUSE_MCP_TOKEN_CACHE_MAX=10000

# Optional — bump to DEBUG to see outgoing HTTP calls in stderr.
LEARNHOUSE_MCP_LOG_LEVEL=INFO
