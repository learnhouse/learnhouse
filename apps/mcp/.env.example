# LearnHouse API endpoint. For self-hosted or dev use http://localhost:1337.
LEARNHOUSE_API_URL=http://localhost:1337

# API token created under Organization Settings → API Tokens.
# Must start with lh_ and is scoped to a single organization.
LEARNHOUSE_API_TOKEN=lh_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Slug of the organization the token belongs to.
# Required because several list/sgoearch endpoints take org_slug (not org_id) in the URL.
LEARNHOUSE_ORG_SLUG=my-org

# Numeric ID of the organization the token belongs to.
# Required for tools that create chapters, activities, or course updates
# (the API requires org_id in the request body for these).
LEARNHOUSE_ORG_ID=1

# Optional — bump to DEBUG to see outgoing HTTP calls in stderr.
LEARNHOUSE_MCP_LOG_LEVEL=INFO
