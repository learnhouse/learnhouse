DESCRIPTION >
    Daily enrollment counts for a single course

NODE course_enrollment_trend_node
SQL >
    %
    SELECT
        toDate(timestamp) AS date,
        count() AS enrollments
    FROM events
    WHERE
        ({{Int64(org_id, 0)}} = 0 OR org_id = {{Int64(org_id, 0)}})
        AND JSONExtractString(properties, 'course_id') = {{String(course_id, '')}}
        AND event_name = 'course_enrolled'
        AND timestamp >= now() - INTERVAL {{Int32(days, 30)}} DAY
    GROUP BY date
    ORDER BY date ASC

TYPE endpoint
