DESCRIPTION >
    Daily views vs enrollments conversion for a single course

NODE course_view_to_enrollment_node
SQL >
    %
    SELECT
        toDate(timestamp) AS date,
        countIf(event_name = 'course_view') AS views,
        countIf(event_name = 'course_enrolled') AS enrollments,
        if(countIf(event_name = 'course_view') > 0,
           round(countIf(event_name = 'course_enrolled') / countIf(event_name = 'course_view') * 100, 1),
           0) AS conversion_rate
    FROM events
    WHERE
        ({{Int64(org_id, 0)}} = 0 OR org_id = {{Int64(org_id, 0)}})
        AND JSONExtractString(properties, 'course_id') = {{String(course_id, '')}}
        AND event_name IN ('course_view', 'course_enrolled')
        AND timestamp >= now() - INTERVAL {{Int32(days, 30)}} DAY
    GROUP BY date
    ORDER BY date ASC

TYPE endpoint
