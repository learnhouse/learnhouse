# PSP integration — trusted shell identity providers (comma-separated)
# Dev uses Auth0; prod uses Okta. Both issuers go in the allowlist.
PSP_TRUSTED_ISSUERS=https://opengov.us.auth0.com/,https://opengov.okta.com/oauth2/default
PSP_TRUSTED_AUDIENCES=https://api.opengov.com
# Public LearnHouse URL the iframe loads (token-exchange landing page lives here)
NEXT_PUBLIC_LEARNHOUSE_URL=https://lms.opengov.com
# The Next.js token-exchange consumer must point PLATFORM_URL + BACKEND_URL at THIS api:
NEXT_PUBLIC_LEARNHOUSE_PLATFORM_URL=https://enablement-api.opengov.com
NEXT_PUBLIC_LEARNHOUSE_BACKEND_URL=https://enablement-api.opengov.com
# Org that PSP-provisioned learners are created in
ENABLEMENT_ORG_ID=1
# Embed mode: set true when LearnHouse is iframed by the PSP shell so session
# cookies use SameSite=None; Secure (required for cross-origin iframe SSO).
NEXT_PUBLIC_LEARNHOUSE_EMBED_MODE=true
# Origin of the PSP shell allowed to frame LearnHouse (CSP frame-ancestors).
PSP_SHELL_ORIGIN=https://app.opengov.com
