# Bridge port
PORT=3001

# LearnHouse API
LH_BASE_URL=https://lms.lanternroute.com
LH_ORG_SLUG=default

# Admin API token. Mint at:
#   POST /api/v1/orgs/{org_id}/api-tokens
# Required rights: users.{create,read,update}, courses.read.
# (See apps/api/src/db/roles.py for the rights schema.)
LH_ADMIN_TOKEN=

# Grow webhook signing secret. Set in Grow's webhook config and copy here.
# Used to verify the X-Grow-Signature header on /webhooks/grow.
# Format / header name TBD — confirm with Grow docs / a real test webhook.
GROW_WEBHOOK_SECRET=

# Resend (email) — BLOCKED on operator getting a verified sending domain.
# Until then the bridge logs the magic-link URL instead of sending email.
RESEND_API_KEY=
RESEND_FROM=
