LEARNHOUSE_INDUSTRY=INDUSTRY_PLACEHOLDER

# Database (Cloud SQL)
LEARNHOUSE_SQL_CONNECTION_STRING=postgresql://user:pass@DB_HOST:5432/learnhouse

# Redis (Memorystore)
LEARNHOUSE_REDIS_CONNECTION_STRING=redis://REDIS_HOST:6379/0

# Auth
LEARNHOUSE_AUTH_JWT_SECRET_KEY=change_me

# LearnHouse AI
LEARNHOUSE_OPENAI_API_KEY=sk-...
LEARNHOUSE_AI_MODEL=gpt-4o-mini
LEARNHOUSE_IS_AI_ENABLED=true

# Custom AI
CUSTOM_AI_ENABLED=true
CUSTOM_AI_MODEL=gpt-4o-mini
CUSTOM_AI_PROMPT_FILE=src/custom/ai/prompts.py

# Hosting
LEARNHOUSE_SITE_NAME=LearnHouse
LEARNHOUSE_DOMAIN=localhost
LEARNHOUSE_ALLOWED_REGEXP=.*localhost.*
LEARNHOUSE_PORT=8000
