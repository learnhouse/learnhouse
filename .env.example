# Public hostname Traefik routes to this stack. Must have a DNS A-record
# pointing at the VPS IP before the first deploy, or Let's Encrypt will fail.
LMS_HOST=lms.lanternroute.com

# Hosting (per docs.learnhouse.app/self-hosting/configuration/environment-variables).
# LEARNHOUSE_DOMAIN is the bare hostname — no scheme, no trailing slash.
LEARNHOUSE_DOMAIN=lms.lanternroute.com
LEARNHOUSE_ALLOWED_ORIGINS=https://lms.lanternroute.com
# Cookie domain: prefix with a dot. Narrow to the LH host — broader domains
# scope cookies to sibling services on the same root (e.g. chat.lanternroute.com).
LEARNHOUSE_COOKIE_DOMAIN=.lms.lanternroute.com

# Frontend public flags — inlined into runtime config. Single-tenant deploys
# set multi-org off; the default org slug is the one the installer seeds.
NEXT_PUBLIC_LEARNHOUSE_DOMAIN=lms.lanternroute.com
NEXT_PUBLIC_LEARNHOUSE_TOP_DOMAIN=lms.lanternroute.com
NEXT_PUBLIC_LEARNHOUSE_HTTPS=true
NEXT_PUBLIC_LEARNHOUSE_MULTI_ORG=false
NEXT_PUBLIC_LEARNHOUSE_DEFAULT_ORG=default
NEXT_PUBLIC_LEARNHOUSE_BACKEND_URL=https://lms.lanternroute.com
NEXT_PUBLIC_LEARNHOUSE_API_URL=https://lms.lanternroute.com/api/v1/
NEXT_PUBLIC_LEARNHOUSE_MEDIA_URL=https://lms.lanternroute.com/api/v1/

# JWT signing. MUST be at least 32 characters.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
LEARNHOUSE_AUTH_JWT_SECRET_KEY=

# Collab websocket + API internal auth. Generate with the same command.
# NOTE: the collab server reads COLLAB_INTERNAL_KEY (no LEARNHOUSE_ prefix).
COLLAB_INTERNAL_KEY=

# NextAuth (web auth). Required by the frontend for session management.
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://lms.lanternroute.com

# Production vs development. Leave false for real deployments — true puts
# uvicorn in --reload mode, which burns CPU and exposes /api/v1/docs.
LEARNHOUSE_DEVELOPMENT_MODE=false

# First-run admin bootstrap. Required — the API's auto-installer creates
# the initial superadmin account with these credentials on first boot.
# After the first successful start you can rotate the password from the
# LH admin UI; the env var stays as a fallback for future auto-installs.
LEARNHOUSE_INITIAL_ADMIN_EMAIL=
LEARNHOUSE_INITIAL_ADMIN_PASSWORD=

# Branding (optional — falls back to LearnHouse defaults).
LEARNHOUSE_SITE_NAME=
LEARNHOUSE_SITE_DESCRIPTION=
LEARNHOUSE_CONTACT_EMAIL=

# Postgres sidecar credentials. Pick any strong password; nothing reaches
# the internet because the DB is on the internal docker network.
POSTGRES_DB=learnhouse
POSTGRES_USER=learnhouse
POSTGRES_PASSWORD=

# Redis sidecar password. Required for the auth-enabled redis command.
REDIS_PASSWORD=

# Transactional email via Resend. Leave blank to disable email (users will
# not receive password-reset or verification mails).
LEARNHOUSE_RESEND_API_KEY=
LEARNHOUSE_SYSTEM_EMAIL_ADDRESS=

# --- Optional integrations (leave empty unless you're using them) ---

# Google OAuth (only if you want "Sign in with Google").
LEARNHOUSE_GOOGLE_CLIENT_ID=
LEARNHOUSE_GOOGLE_CLIENT_SECRET=

# Gemini AI (course-builder features). Not needed for a basic course.
LEARNHOUSE_GEMINI_API_KEY=
LEARNHOUSE_IS_AI_ENABLED=false

# S3-compatible uploads. If empty, uploads go to the lms_content volume.
LEARNHOUSE_CONTENT_DELIVERY_TYPE=filesystem
LEARNHOUSE_S3_API_BUCKET_NAME=
LEARNHOUSE_S3_API_ENDPOINT_URL=

# Tinybird analytics. Leave empty to disable.
LEARNHOUSE_TINYBIRD_API_URL=
LEARNHOUSE_TINYBIRD_INGEST_TOKEN=
LEARNHOUSE_TINYBIRD_READ_TOKEN=
